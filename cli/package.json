{
  "name": "@wizzlethorpe/vaults",
  "version": "0.3.0",
  "description": "Sync an Obsidian vault to a Cloudflare-hosted wiki with role-based access. Renders locally, deploys to Cloudflare Pages.",
  "keywords": [
    "obsidian",
    "vault",
    "wiki",
    "cloudflare-pages",
    "ttrpg",
    "knowledge-base"
  ],
  "homepage": "https://github.com/wizzlethorpe/vaults-cli#readme",
  "bugs": "https://github.com/wizzlethorpe/vaults-cli/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wizzlethorpe/vaults-cli.git",
    "directory": "cli"
  },
  "license": "MIT",
  "author": "wizzlethorpe",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "vaults": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@types/js-yaml": "^4.0.9",
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "mdast-util-find-and-replace": "^3.0.1",
    "picomatch": "^4.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "sharp": "^0.33.5",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "wrangler": "^4.87.0"
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.10.0",
    "@types/picomatch": "^3.0.1",
    "@types/unist": "^3.0.3",
    "typescript": "^5.9.3"
  }
}
